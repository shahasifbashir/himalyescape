---
import type { TourPackage } from "@/data/packages";
import { inr, originalPrice } from "@/utils/format";
import { whatsappUrl } from "@/config/site";
import Icon from "./Icon.astro";

interface Props {
  pkg: TourPackage;
  /** first cards can load eagerly, rest lazy */
  eager?: boolean;
}
const { pkg, eager = false } = Astro.props;

const hasDiscount = !!pkg.discountPercent && pkg.discountPercent > 0;
const wasPrice = hasDiscount ? originalPrice(pkg.priceFrom, pkg.discountPercent!) : 0;
---

<article class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:shadow-lg">
  <div class="relative aspect-[4/3] overflow-hidden">
    <img
      src={pkg.image}
      alt={pkg.imageAlt}
      width="1200"
      height="900"
      loading={eager ? "eager" : "lazy"}
      decoding="async"
      class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
    />
    <span class="absolute left-3 top-3 rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-[var(--brand-primary)] backdrop-blur">
      {pkg.region}
    </span>
    {hasDiscount && (
      <span class="absolute right-3 top-3 rounded-full bg-[var(--brand-accent)] px-3 py-1 text-xs font-bold text-slate-900 shadow">
        {pkg.discountPercent}% OFF
      </span>
    )}
  </div>

  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-center gap-2 text-xs font-medium text-slate-500">
      <Icon name="clock" size={14} /> {pkg.duration}
    </div>
    <h3 class="mt-2 text-lg font-bold text-slate-900">{pkg.title}</h3>
    <p class="mt-2 text-sm leading-relaxed text-slate-600">{pkg.summary}</p>

    <ul class="mt-4 space-y-1.5">
      {pkg.highlights.slice(0, 3).map((h) => (
        <li class="flex items-start gap-2 text-sm text-slate-700">
          <Icon name="check" size={16} class="mt-0.5 shrink-0 text-[var(--brand-primary)]" />
          <span>{h}</span>
        </li>
      ))}
    </ul>

    <div class="mt-5 flex items-end justify-between border-t border-slate-100 pt-4">
      <div>
        <p class="text-xs text-slate-500">Starting from</p>
        {hasDiscount && (
          <p class="flex items-center gap-2">
            <span class="text-sm text-slate-400 line-through">{inr(wasPrice)}</span>
            <span class="rounded bg-red-50 px-1.5 py-0.5 text-xs font-semibold text-red-600">
              Save {pkg.discountPercent}%
            </span>
          </p>
        )}
        <p class="text-xl font-bold text-slate-900">
          {inr(pkg.priceFrom)}<span class="text-sm font-normal text-slate-500">/person</span>
        </p>
      </div>
      <a
        href={whatsappUrl()}
        target="_blank"
        rel="noopener"
        class="btn-primary !px-4 !py-2 text-sm"
        aria-label={`Book ${pkg.title}`}
      >
        Book Now
      </a>
    </div>
  </div>
</article>
