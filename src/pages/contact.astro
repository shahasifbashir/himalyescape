---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
import { siteConfig, whatsappUrl } from "@/config/site";

const { contact, address } = siteConfig;
---

<BaseLayout
  title="Contact Us"
  description={`Get in touch with ${siteConfig.name} to plan your Kashmir or Ladakh trip. Call ${contact.phone} or message us on WhatsApp.`}
>
  <section class="border-b border-slate-100 bg-slate-50">
    <div class="container-x py-14 text-center">
      <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">Let's plan your trip</h1>
      <p class="mx-auto mt-3 max-w-2xl text-slate-600">
        Have a question or ready to book? Reach out — we usually reply within a few minutes during business hours.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-x grid gap-10 lg:grid-cols-2">
      <!-- Contact details -->
      <div class="space-y-4">
        <a href={whatsappUrl()} target="_blank" rel="noopener" class="flex items-center gap-4 rounded-2xl border border-slate-200 p-5 transition hover:border-[var(--brand-primary)] hover:shadow-sm">
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-[#25D366]/10 text-[#25D366]"><Icon name="whatsapp" size={24} /></span>
          <span>
            <span class="block text-sm text-slate-500">WhatsApp (fastest)</span>
            <span class="block font-semibold text-slate-900">{contact.phone}</span>
          </span>
        </a>
        <a href={`tel:${contact.phoneRaw}`} class="flex items-center gap-4 rounded-2xl border border-slate-200 p-5 transition hover:border-[var(--brand-primary)] hover:shadow-sm">
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-[var(--brand-primary)]/10 text-[var(--brand-primary)]"><Icon name="phone" size={22} /></span>
          <span>
            <span class="block text-sm text-slate-500">Call us</span>
            <span class="block font-semibold text-slate-900">{contact.phone}</span>
          </span>
        </a>
        <a href={`mailto:${contact.email}`} class="flex items-center gap-4 rounded-2xl border border-slate-200 p-5 transition hover:border-[var(--brand-primary)] hover:shadow-sm">
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-[var(--brand-primary)]/10 text-[var(--brand-primary)]"><Icon name="email" size={22} /></span>
          <span>
            <span class="block text-sm text-slate-500">Email</span>
            <span class="block font-semibold text-slate-900">{contact.email}</span>
          </span>
        </a>
        <div class="flex items-center gap-4 rounded-2xl border border-slate-200 p-5">
          <span class="flex h-12 w-12 items-center justify-center rounded-full bg-[var(--brand-primary)]/10 text-[var(--brand-primary)]"><Icon name="pin" size={22} /></span>
          <span>
            <span class="block text-sm text-slate-500">Visit us</span>
            <span class="block font-semibold text-slate-900">{address.street}, {address.city}</span>
            <span class="block text-sm text-slate-500">{address.state} {address.postalCode}, {address.country}</span>
          </span>
        </div>
        <div class="flex items-center gap-3 pt-2">
          {siteConfig.socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} class="rounded-full border border-slate-200 p-3 text-slate-600 transition hover:border-[var(--brand-primary)] hover:text-[var(--brand-primary)]">
              <Icon name={s.icon} size={20} />
            </a>
          ))}
        </div>
      </div>

      <!-- Enquiry form -->
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-bold text-slate-900">Send an enquiry</h2>
        <p class="mt-1 text-sm text-slate-500">Fill this in and we'll get back to you shortly.</p>
        <!--
          NOTE: This form posts to a placeholder. Connect it to a form backend
          (Formspree, Web3Forms, Netlify Forms, etc.) by updating the `action`.
        -->
        <form action="#" method="POST" class="mt-5 space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700">Name</label>
            <input id="name" name="name" type="text" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2.5 focus:border-[var(--brand-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--brand-primary)]" />
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="email" class="block text-sm font-medium text-slate-700">Email</label>
              <input id="email" name="email" type="email" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2.5 focus:border-[var(--brand-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--brand-primary)]" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-slate-700">Phone</label>
              <input id="phone" name="phone" type="tel" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2.5 focus:border-[var(--brand-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--brand-primary)]" />
            </div>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-slate-700">Your trip idea</label>
            <textarea id="message" name="message" rows="4" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2.5 focus:border-[var(--brand-primary)] focus:outline-none focus:ring-1 focus:ring-[var(--brand-primary)]"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full">Send enquiry</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
