---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
import { siteConfig, whatsappUrl } from "@/config/site";

const yearsActive = new Date().getFullYear() - siteConfig.foundedYear;

const stats = [
  { value: `${yearsActive}+`, label: "Years of experience" },
  { value: "2,000+", label: "Happy travellers" },
  { value: "50+", label: "Curated itineraries" },
  { value: "4.9★", label: "Average rating" },
];

const values = [
  { icon: "pin", title: "Rooted locally", text: "We live here. Our itineraries come from genuine love and deep knowledge of the region." },
  { icon: "check", title: "Honest & transparent", text: "Clear pricing, no hidden charges, and only recommendations we'd give our own family." },
  { icon: "star", title: "Guest-first always", text: "Every trip is tailored to you — your pace, your interests, your budget." },
];
---

<BaseLayout
  title="About Us"
  description={`Learn about ${siteConfig.name}, a locally-rooted travel company specialising in Kashmir & Ladakh since ${siteConfig.foundedYear}.`}
>
  <section class="border-b border-slate-100 bg-slate-50">
    <div class="container-x py-14 text-center">
      <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">About {siteConfig.name}</h1>
      <p class="mx-auto mt-3 max-w-2xl text-slate-600">{siteConfig.tagline}</p>
    </div>
  </section>

  <section class="section">
    <div class="container-x grid items-center gap-10 lg:grid-cols-2">
      <img
        src="https://images.unsplash.com/photo-1712388430474-ace0c16051e2?auto=format&fit=crop&w=1000&q=70"
        alt="A guide leading travellers through a Himalayan valley"
        width="1000"
        height="750"
        loading="lazy"
        decoding="async"
        class="rounded-2xl object-cover shadow-sm"
      />
      <div>
        <p class="eyebrow">Our story</p>
        <h2 class="mt-2 text-3xl font-bold text-slate-900">Sharing the Himalayas we call home</h2>
        <p class="mt-4 leading-relaxed text-slate-600">
          {siteConfig.name} was founded in {siteConfig.foundedYear} by a small team of
          Kashmir- and Ladakh-based travellers with one goal: to help visitors experience the
          real Himalayas — safely, comfortably and authentically.
        </p>
        <p class="mt-4 leading-relaxed text-slate-600">
          From a single houseboat and a shared jeep, we've grown into a trusted name for
          thousands of travellers, while keeping the personal, local touch that started it all.
        </p>
        <a href={whatsappUrl()} target="_blank" rel="noopener" class="btn-primary mt-6">
          <Icon name="whatsapp" size={18} /> Talk to our team
        </a>
      </div>
    </div>
  </section>

  <section class="bg-[var(--brand-primary)]">
    <div class="container-x grid grid-cols-2 gap-6 py-12 text-center text-white lg:grid-cols-4">
      {stats.map((s) => (
        <div>
          <p class="text-3xl font-extrabold sm:text-4xl">{s.value}</p>
          <p class="mt-1 text-sm text-teal-50">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">What we stand for</p>
        <h2 class="mt-2 text-3xl font-bold text-slate-900">Our values</h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {values.map((v) => (
          <div class="rounded-2xl border border-slate-200 p-6">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-[var(--brand-primary)]/10 text-[var(--brand-primary)]">
              <Icon name={v.icon} size={24} />
            </div>
            <h3 class="mt-4 font-bold text-slate-900">{v.title}</h3>
            <p class="mt-2 text-sm text-slate-600">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
