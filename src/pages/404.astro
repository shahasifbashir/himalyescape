---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
---

<BaseLayout title="Page not found" noindex>
  <section class="section">
    <div class="container-x flex min-h-[50vh] flex-col items-center justify-center text-center">
      <p class="text-6xl font-extrabold text-[var(--brand-primary)]">404</p>
      <h1 class="mt-4 text-2xl font-bold text-slate-900">This trail leads nowhere</h1>
      <p class="mt-2 max-w-md text-slate-600">
        The page you're looking for has wandered off. Let's get you back on track.
      </p>
      <a href="/" class="btn-primary mt-6">Back to home <Icon name="arrow" size={18} /></a>
    </div>
  </section>
</BaseLayout>
