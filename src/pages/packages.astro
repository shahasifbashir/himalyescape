---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PackageCard from "@/components/PackageCard.astro";
import { packages } from "@/data/packages";
import { siteConfig } from "@/config/site";
import { inr } from "@/utils/format";

// Build ItemList structured data for the packages (rich SEO).
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    itemListElement: packages.map((p, i) => ({
      "@type": "ListItem",
      position: i + 1,
      item: {
        "@type": "TouristTrip",
        name: p.title,
        description: p.summary,
        image: p.image,
        offers: {
          "@type": "Offer",
          price: p.priceFrom,
          priceCurrency: "INR",
          availability: "https://schema.org/InStock",
        },
      },
    })),
  },
];
---

<BaseLayout
  title="Tour Packages"
  description={`Browse ${packages.length} handcrafted Kashmir & Ladakh tour packages from ${siteConfig.name}. Prices starting from ${inr(Math.min(...packages.map((p) => p.priceFrom)))}.`}
  jsonLd={jsonLd}
>
  <section class="border-b border-slate-100 bg-slate-50">
    <div class="container-x py-14 text-center">
      <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">Kashmir & Ladakh Tour Packages</h1>
      <p class="mx-auto mt-3 max-w-2xl text-slate-600">
        Every package is fully customisable. Pick one you love and we'll tailor the dates,
        stays and inclusions to suit you.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {packages.map((pkg, i) => <PackageCard pkg={pkg} eager={i < 3} />)}
      </div>
    </div>
  </section>
</BaseLayout>
