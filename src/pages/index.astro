---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PackageCard from "@/components/PackageCard.astro";
import Icon from "@/components/Icon.astro";
import { siteConfig, whatsappUrl } from "@/config/site";
import { featuredPackages } from "@/data/packages";
import { destinations } from "@/data/destinations";
import { testimonials } from "@/data/testimonials";

const heroImage =
  "https://images.unsplash.com/photo-1590050752117-238cb0fb12b1?auto=format&fit=crop&w=1920&q=70";

const whyUs = [
  { icon: "pin", title: "Local Experts", text: "Born-and-raised guides who know every hidden valley and viewpoint." },
  { icon: "check", title: "Handpicked Stays", text: "Verified houseboats, hotels and camps — comfort you can trust." },
  { icon: "phone", title: "24×7 Support", text: "Real humans on call throughout your journey, whenever you need us." },
  { icon: "star", title: "Best Value", text: "Transparent pricing with no hidden costs and fully customisable trips." },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative flex min-h-[88vh] items-center">
    <img
      src={heroImage}
      alt="Snow-capped Himalayan peaks reflected in a still lake"
      width="1920"
      height="1080"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-slate-900/70 via-slate-900/40 to-slate-900/70"></div>

    <div class="container-x relative py-24 text-white">
      <p class="mb-4 inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-1.5 text-sm font-medium backdrop-blur">
        <Icon name="star" size={14} class="text-[var(--brand-accent)]" /> Rated 5★ by 2,000+ happy travellers
      </p>
      <h1 class="max-w-3xl text-4xl font-extrabold leading-tight sm:text-5xl lg:text-6xl">
        {siteConfig.tagline}
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-slate-100">{siteConfig.description}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/packages" class="btn-accent">Explore Packages <Icon name="arrow" size={18} /></a>
        <a href={whatsappUrl()} target="_blank" rel="noopener" class="btn-outline">
          <Icon name="whatsapp" size={18} /> Plan on WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Featured packages -->
  <section class="section">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Handcrafted Journeys</p>
        <h2 class="mt-2 text-3xl font-bold text-slate-900 sm:text-4xl">Featured Tour Packages</h2>
        <p class="mt-3 text-slate-600">Our most-loved trips across Kashmir & Ladakh, ready to book or customise.</p>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredPackages.map((pkg, i) => <PackageCard pkg={pkg} eager={i === 0} />)}
      </div>
      <div class="mt-10 text-center">
        <a href="/packages" class="btn-primary">View all packages <Icon name="arrow" size={18} /></a>
      </div>
    </div>
  </section>

  <!-- Destinations -->
  <section class="section bg-slate-50">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Where to go</p>
        <h2 class="mt-2 text-3xl font-bold text-slate-900 sm:text-4xl">Explore Our Destinations</h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {Object.values(destinations).map((d) => (
          <a href={`/destinations/${d.slug}`} class="group relative overflow-hidden rounded-2xl">
            <img
              src={d.heroImage}
              alt={d.heroImageAlt}
              width="1600"
              height="1000"
              loading="lazy"
              decoding="async"
              class="aspect-[16/10] w-full object-cover transition duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 to-transparent"></div>
            <div class="absolute bottom-0 p-6 text-white">
              <h3 class="text-2xl font-bold">{d.name}</h3>
              <p class="text-sm text-slate-200">{d.headline}</p>
              <span class="mt-2 inline-flex items-center gap-1 text-sm font-semibold text-[var(--brand-accent)]">
                Discover more <Icon name="arrow" size={16} />
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why choose us -->
  <section class="section">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Why travel with us</p>
        <h2 class="mt-2 text-3xl font-bold text-slate-900 sm:text-4xl">Your trip, in expert hands</h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {whyUs.map((f) => (
          <div class="rounded-2xl border border-slate-200 p-6 text-center">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-[var(--brand-primary)]/10 text-[var(--brand-primary)]">
              <Icon name={f.icon} size={24} />
            </div>
            <h3 class="mt-4 font-bold text-slate-900">{f.title}</h3>
            <p class="mt-2 text-sm text-slate-600">{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section bg-slate-50">
    <div class="container-x">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">Loved by travellers</p>
        <h2 class="mt-2 text-3xl font-bold text-slate-900 sm:text-4xl">What our guests say</h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {testimonials.map((t) => (
          <figure class="flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex gap-1 text-[var(--brand-accent)]">
              {Array.from({ length: t.rating }).map(() => <Icon name="star" size={16} />)}
            </div>
            <blockquote class="mt-4 flex-1 text-slate-700">“{t.quote}”</blockquote>
            <figcaption class="mt-4 text-sm font-semibold text-slate-900">
              {t.name} <span class="font-normal text-slate-500">· {t.location}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[var(--brand-primary)]">
    <div class="container-x flex flex-col items-center gap-6 py-16 text-center text-white">
      <h2 class="max-w-2xl text-3xl font-bold sm:text-4xl">Ready for your Himalayan adventure?</h2>
      <p class="max-w-xl text-teal-50">Tell us your dates and interests — we'll craft the perfect itinerary for you.</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href={whatsappUrl()} target="_blank" rel="noopener" class="btn-accent"><Icon name="whatsapp" size={18} /> Chat with us</a>
        <a href="/custom-package" class="btn-outline">Build a custom trip</a>
      </div>
    </div>
  </section>
</BaseLayout>
